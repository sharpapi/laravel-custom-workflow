{
  "name": "sharpapi/laravel-custom-workflow",
  "description": "Laravel wrapper for SharpAPI Custom AI Workflow SDK - build and execute no-code AI API endpoints",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "SharpAPI",
    "laravel",
    "custom",
    "workflow",
    "ai",
    "api",
    "no-code",
    "php"
  ],
  "homepage": "https://sharpapi.com/",
  "authors": [
    {
      "name": "A2Z WEB LTD",
      "homepage": "https://sharpapi.com/"
    }
  ],
  "require": {
    "php": ">=8.1",
    "laravel/framework": "^10.0|^11.0|^12.0",
    "sharpapi/php-custom-workflow": "^1.0.0"
  },
  "autoload": {
    "psr-4": {
      "SharpAPI\\LaravelCustomWorkflow\\": "src/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "SharpAPI\\LaravelCustomWorkflow\\ServiceProvider"
      ],
      "aliases": {
        "CustomWorkflow": "SharpAPI\\LaravelCustomWorkflow\\Facades\\CustomWorkflow"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "support": {
    "source": "https://github.com/sharpapi/laravel-custom-workflow",
    "issues": "https://github.com/sharpapi/laravel-custom-workflow/issues"
  }
}
